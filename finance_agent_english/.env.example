# LLM配置
# 你可以使用火山方舟、通义千问、或任何OpenAI兼容格式的API
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_API_KEY=ark-你的api-key在这里
LLM_MODEL=volcengine-plan/ark-code-latest

# ========== 搜索配置 ==========
# 选择搜索后端: serper (推荐免费) | exa (你的OpenClaw当前在用) | brave | bing | google
# - SerperDev: 1000次/月免费，足够个人使用  https://serper.dev/
# - Exa: 专门给AI的搜索，你OpenClaw当前就是用这个  https://exa.ai/
# - Brave Search: 免费额度大  https://brave.com/search/api/
# - Bing: 微软每月1000次免费
# - Google Custom Search: 需要API key

SEARCH_BACKEND=exa

# Exa (你OpenClaw当前在用，可以复用同一个API KEY)
EXA_API_KEY=your_exa_api_key_here

# SerperDev (免费推荐)
# SERPER_API_KEY=your_serper_api_key_here

# Brave Search
# BRAVE_API_KEY=your_brave_api_key_here

# Bing Search
# BING_API_KEY=your_bing_api_key_here

# Google Custom Search
# GOOGLE_SEARCH_API_KEY=your_google_api_key_here
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
